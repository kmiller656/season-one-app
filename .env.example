# Copy this file to ".env" and fill in your own values.
# All client-exposed variables MUST be prefixed with VITE_.

# Supabase — Project Settings → API
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Maps JavaScript API key with the "Places API" enabled.
# Restrict by HTTP referrer (app.seasononehealthcare.com) in the Google Cloud console.
VITE_GOOGLE_MAPS_KEY=your_google_maps_key

# Web3Forms access key (used by the "My Team" contact form)
VITE_WEB3FORMS_KEY=29ab9da0-4cba-45a4-a0dc-57e0b49e7737
